# ===========================================================================
# Agentic Clinical Decision Support — environment configuration
# Copy to `.env`. EVERYTHING IS OPTIONAL — with no keys the app runs in DEMO
# MODE using the deterministic clinical engine (fully offline).
# ===========================================================================

# --- LLM provider (set ONE key to enable LIVE mode) ------------------------
# LLM_PROVIDER: auto | openai | anthropic | demo   (default: auto)
LLM_PROVIDER=auto
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- RAG / vector store ----------------------------------------------------
# RAG_BACKEND: auto | chromadb | keyword   (auto tries Chroma, falls back)
RAG_BACKEND=auto
CHROMA_DIR=.chroma
EMBEDDING_PROVIDER=default

# --- persistence -----------------------------------------------------------
SQLITE_PATH=cds.db

# --- server ----------------------------------------------------------------
CORS_ORIGINS=*
